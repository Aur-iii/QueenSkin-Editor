{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QueenSkin Editor",
  "version": "0.2.0",
  "identifier": "com.auri.queenskin",
  "build": {
    "beforeDevCommand": null,
    "beforeBuildCommand": null,
    "frontendDist": "../src-ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "QueenSkin Editor",
        "width": 1440,
        "height": 920,
        "minWidth": 1100,
        "minHeight": 760,
        "maximized": true,
        "resizable": true,
        "center": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["main-capability"]
    }
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.png", "icons/icon.ico"],
    "resources": {
      "icons/qse-document.ico": "qse-document.ico",
      "icons/qse-document.icns": "qse-document.icns"
    },
    "fileAssociations": [
      {
        "ext": ["qse"],
        "name": "QueenSkin.Project",
        "description": "QueenSkin Editor Project File",
        "role": "Editor",
        "mimeType": "application/x-queenskin-project",
        "exportedType": {
          "identifier": "com.auri.queenskin.project",
          "conformsTo": ["public.data"]
        }
      }
    ],
    "windows": {
      "nsis": {
        "installerHooks": "windows/hooks.nsh"
      }
    },
    "macOS": {
      "files": {
        "Resources/qse-document.icns": "icons/qse-document.icns"
      },
      "infoPlist": "macos/Info.plist"
    }
  }
}
